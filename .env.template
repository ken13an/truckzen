# ============================================================
# TRUCKZEN — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to git
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...YOUR_SERVICE_ROLE_KEY

# ── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://truckzen.com
# For local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── YOUR SHOP ────────────────────────────────────────────────
# Get this UUID after running the shop seed in Supabase
TRUCKZEN_SHOP_ID=YOUR_SHOP_UUID_HERE

# ── ANTHROPIC (Claude API) ───────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── TELEGRAM BOT ─────────────────────────────────────────────
# Get from: @BotFather on Telegram
# 1. Message @BotFather
# 2. /newbot → name it "TruckZen Service Writer" → username @servicewriter
# 3. Copy the token
TELEGRAM_BOT_TOKEN=7312948201:AAF...
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# ── STRIPE ───────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── TWILIO (SMS) ─────────────────────────────────────────────
# Get from: console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+17135551234

# ── RESEND (Email) ───────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...
EMAIL_FROM=TruckZen <noreply@truckzen.com>

# ── QUICKBOOKS ONLINE ────────────────────────────────────────
# Get from: developer.intuit.com → Create App → OAuth 2.0
QUICKBOOKS_CLIENT_ID=...
QUICKBOOKS_CLIENT_SECRET=...
QUICKBOOKS_REDIRECT_URI=https://truckzen.com/api/qbo/callback
# Populated after OAuth:
# QUICKBOOKS_ACCESS_TOKEN=...
# QUICKBOOKS_REFRESH_TOKEN=...
# QUICKBOOKS_REALM_ID=...

# ── MONDAY.COM MIGRATION (one-time use) ──────────────────────
MONDAY_API_KEY=eyJhbGc...
MONDAY_BOARD_ID=1234567890

# ── FLEETIO MIGRATION (one-time use) ─────────────────────────
FLEETIO_API_KEY=...
FLEETIO_ACCOUNT_TOKEN=...

# ── QR PAYMENT ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_PAYMENT_SECRET=your_64_char_random_string_here

# ── GPS TELEMATICS (optional, add later) ─────────────────────
# SAMSARA_API_KEY=samsara_api_...
# MOTIVE_API_KEY=...
# GEOTAB_USERNAME=...
# GEOTAB_PASSWORD=...
# GEOTAB_DATABASE=...
