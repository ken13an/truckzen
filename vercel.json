{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",

  "regions": ["iad1"],

  "headers": [
    {
      "source": "/api/telegram",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/kiosk/:path*",
      "destination": "/kiosk/:path*"
    }
  ],

  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    }
  ],

  "trailingSlash": false,

  "cleanUrls": true,

  "crons": [
    {
      "path": "/api/cron/pm-alerts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/compliance-alerts",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/invoice-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin/backup",
      "schedule": "0 2 * * 0"
    }
  ]
}
